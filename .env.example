PORT=3000
# Reverse-proxy hops in front of the app (Express trust proxy).
# Local dev: 1. Production behind Cloudflare -> Caddy: 2.
TRUST_PROXY_HOPS=1

# ── Nightly backup email reports (Resend) ──────────────────────────
# The cron backup (deploy/backup-db.sh) emails a daily OK/FAILED report.
# Leave RESEND_API_KEY unset to disable email entirely (backups still run).
# RESEND_API_KEY=re_your_key_here
# BACKUP_EMAIL_TO=will.lehmann@powval.com
# BACKUP_EMAIL_FROM=PowVal Backups <backups@powval.com>
#
# Optional dead-man's-switch backstop: a healthchecks.io ping URL. Catches the
# case where the whole box/cron dies and no email (success or failure) is sent.
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# ── Waitlist welcome email (Resend) ────────────────────────────────
# When a consumer (B2C) joins the waitlist, the app sends them a welcome email
# via the SAME Resend account as the backups above (reuses RESEND_API_KEY).
# The From domain must be verified in Resend — powval.com already is, since the
# backups send from @powval.com. Leave WAITLIST_EMAIL_FROM unset to disable the
# welcome email (signups still work).
# WAITLIST_EMAIL_FROM=powval <no-reply@powval.com>
#
# Optional: where replies route, since no-reply@ isn't monitored. Unset = none.
# WAITLIST_EMAIL_REPLY_TO=hello@powval.com

# ── eBay Marketplace Account Deletion endpoint ─────────────────────
# Required for eBay API production access. The route at /deletion answers
# eBay's validation handshake using these. BOTH must EXACTLY match the values
# entered in the eBay developer portal (Alerts & Notifications) — any
# mismatch (trailing slash, http vs https) fails validation.
# EBAY_DELETION_VERIFICATION_TOKEN=your_32_to_80_char_token
# EBAY_DELETION_ENDPOINT=https://powval.com/deletion
