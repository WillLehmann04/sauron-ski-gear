{{!--
  powval B2C waitlist welcome email. Sent when a consumer joins the waitlist.
  Data: name (optional; greeting falls back to "there")

  Design: PowVal's "Night Mountain" system, top to bottom — one cohesive ink
  surface (no white SaaS body). The hero is a pre-rendered raster scene
  (public/images/email-hero.jpg: ink sky, star field, atmospheric ridges, the
  orange chart-line cresting a peak to a glowing beacon, slope-cut into the
  body, Barlow Condensed headline) so it renders identically everywhere and
  survives Outlook. bgcolor + alt text cover image-blocking. Barlow Condensed
  loads via web font for the live headings/button (Apple Mail-class clients);
  a condensed system stack is the fallback. One beacon-orange action per
  region. Links are absolute (no relative paths in email).
  Email-client-safe: tables, inline styles, hex bgcolor on every dark surface
  so dark-mode clients don't repaint it.
--}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark light">
  <meta name="supported-color-schemes" content="dark light">
  <title>You're on the powval waitlist</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet">
</head>
<body style="margin:0;padding:0;background:#04080e;-webkit-text-size-adjust:100%;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
  <!-- preheader: hidden summary shown in inbox preview -->
  <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
    You're on the powval waitlist. We'll email you the moment it's live.
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" bgcolor="#04080e" style="background:#04080e;padding:24px 12px;">
    <tr><td align="center">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" bgcolor="#091828" style="max-width:600px;width:100%;background:#091828;border-radius:16px;overflow:hidden;border:1px solid #16304a;">

        <!-- header bar: logo lockup -->
        <tr><td bgcolor="#060d16" style="background:#060d16;padding:15px 26px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
            <td width="30" valign="middle" style="padding-right:9px;">
              <img src="https://powval.com/images/powval-icon-60.png" width="30" height="30" alt="powval" style="display:block;border:0;border-radius:7px;">
            </td>
            <td valign="middle" style="font-family:'Barlow Condensed','Arial Narrow',Helvetica,sans-serif;font-weight:800;font-size:23px;letter-spacing:0.02em;color:#ffffff;">pow<span style="color:#e87b1e;">val</span></td>
            <td valign="middle" align="right" style="font-size:11px;font-weight:bold;letter-spacing:0.18em;text-transform:uppercase;color:#6f93b6;">Waitlist</td>
          </tr></table>
        </td></tr>

        <!-- hero: the Night Mountain scene (slope-cut bottom steps into the body) -->
        <tr><td bgcolor="#060d16" style="background:#060d16;font-size:0;line-height:0;">
          <img src="https://powval.com/images/email-hero.jpg" width="600" alt="powval — you're on the list" style="display:block;width:100%;max-width:600px;height:auto;border:0;">
        </td></tr>

        <!-- body (ink-850) -->
        <tr><td bgcolor="#091828" style="background:#091828;padding:26px 32px 32px;">
          <p style="margin:0 0 16px;font-size:18px;font-weight:bold;line-height:1.4;color:#ffffff;">
            Hey {{#if name}}{{name}}{{else}}there{{/if}},
          </p>

          <p style="margin:0 0 6px;font-size:15px;line-height:1.7;color:#c7dbed;">
            You're on the powval waitlist. We're building the straight answer to one question: what's your ski and snowboard gear actually worth. When you can price it and sell it here, you'll be first to know.
          </p>

          <!-- what's next: two editorial link rows (no card grid) -->
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:22px 0 4px;">
            <tr><td style="border-top:1px solid #1c3a55;padding:15px 0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
                <td valign="middle">
                  <a href="https://powval.com/roadmap" style="text-decoration:none;display:block;">
                    <span style="font-family:'Barlow Condensed','Arial Narrow',Helvetica,sans-serif;font-size:19px;font-weight:700;letter-spacing:0.03em;text-transform:uppercase;color:#ffffff;">The roadmap</span>
                    <span style="display:block;margin-top:2px;font-size:13px;color:#8aa6c2;">Where powval goes next.</span>
                  </a>
                </td>
                <td valign="middle" align="right" width="28">
                  <a href="https://powval.com/roadmap" style="text-decoration:none;color:#5e83a6;font-size:20px;font-weight:bold;">&rarr;</a>
                </td>
              </tr></table>
            </td></tr>
            <tr><td style="border-top:1px solid #1c3a55;border-bottom:1px solid #1c3a55;padding:15px 0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
                <td valign="middle">
                  <a href="https://powval.com/changelog" style="text-decoration:none;display:block;">
                    <span style="font-family:'Barlow Condensed','Arial Narrow',Helvetica,sans-serif;font-size:19px;font-weight:700;letter-spacing:0.03em;text-transform:uppercase;color:#ffffff;">What's new</span>
                    <span style="display:block;margin-top:2px;font-size:13px;color:#8aa6c2;">Everything shipped so far.</span>
                  </a>
                </td>
                <td valign="middle" align="right" width="28">
                  <a href="https://powval.com/changelog" style="text-decoration:none;color:#5e83a6;font-size:20px;font-weight:bold;">&rarr;</a>
                </td>
              </tr></table>
            </td></tr>
          </table>

          <!-- share nudge + the single beacon action -->
          <p style="margin:24px 0 16px;font-size:15px;line-height:1.65;color:#c7dbed;">
            <strong style="color:#ffffff;">Know someone sitting on gear they'll never ride again?</strong> Send them our way.
          </p>
          <a href="https://powval.com" style="display:inline-block;background:#e87b1e;color:#ffffff;text-decoration:none;font-family:'Barlow Condensed','Arial Narrow',Helvetica,sans-serif;font-size:18px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;padding:13px 28px;border-radius:8px;box-shadow:0 6px 20px rgba(232,123,30,0.34);">Tell a mate</a>

          <p style="margin:28px 0 0;font-size:15px;line-height:1.6;color:#8aa6c2;">
            See you on the hill,<br><strong style="color:#ffffff;">the powval crew</strong>
          </p>
        </td></tr>

        <!-- footer -->
        <tr><td bgcolor="#060d16" style="background:#060d16;border-top:1px solid #16304a;padding:16px 32px;">
          <p style="margin:0;font-size:12px;line-height:1.55;color:#6f8aa3;">You're getting this because you joined the powval waitlist at <a href="https://powval.com" style="color:#8aa6c2;text-decoration:underline;">powval.com</a>. We'll only email you about your spot and launch news.</p>
        </td></tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
