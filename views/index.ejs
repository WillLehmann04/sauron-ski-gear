<nav class="nav" id="nav">
  <div class="nav__inner">
    <a class="nav__logo" href="/">Gear<span>Worth</span></a>
    <div class="nav__links" aria-hidden="true">
      <span class="nav__link">Estimate</span>
      <span class="nav__link">Buy</span>
      <span class="nav__link">Sell</span>
    </div>
    <a class="nav__cta" href="#join">Join the list</a>
  </div>
</nav>

<header class="hero">
  <canvas class="hero__snow" id="snow" aria-hidden="true"></canvas>

  <div class="hero__peaks" aria-hidden="true">
    <svg viewBox="0 0 1440 130" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="pkGradBack" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="rgba(22,65,112,0.52)"/>
          <stop offset="100%" stop-color="rgba(5,14,28,0.04)"/>
        </linearGradient>
        <linearGradient id="pkGradFront" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="rgba(8,28,52,0.78)"/>
          <stop offset="100%" stop-color="rgba(3,10,20,0.08)"/>
        </linearGradient>
      </defs>
      <path d="M0,130 L0,102 L220,60 L430,82 L640,38 L860,68 L1100,44 L1310,74 L1440,52 L1440,130 Z" fill="url(#pkGradBack)"/>
      <path d="M0,130 L0,88 L145,32 L255,70 L400,12 L525,55 L648,6 L768,50 L905,18 L1035,52 L1180,8 L1295,48 L1395,20 L1440,40 L1440,130 Z" fill="url(#pkGradFront)"/>
    </svg>
  </div>

  <div class="hero__slope" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,80 1440,14 1440,80" fill="#fafcff"/>
    </svg>
  </div>

  <div class="hero__content">
    <p class="hero__eyebrow">
      <span class="hero__eyebrow-dot" aria-hidden="true"></span>
      Ski &amp; snowboard gear resale
    </p>
    <h1 class="hero__title">
      <span class="hero__line">What's</span>
      <span class="hero__line">My Gear</span>
      <span class="hero__line hero__accent">Worth?</span>
    </h1>
    <p class="hero__sub">Enter your ski or snowboard gear. Get a realistic resale range in seconds.</p>
    <div class="hero__meta">
      <span class="hero__meta-rule" aria-hidden="true"></span>
      <p class="hero__meta-text">Free at launch &middot; no account required</p>
    </div>
  </div>

  <div class="hero__visual" aria-hidden="true">
    <div class="val-panel">

      <div class="val-s val-s--gear">
        <p class="val-s__eyebrow">What's your gear?</p>
        <div class="val-s__rule"><span class="val-s__rule-fill"></span></div>
        <div class="val-form">
          <div class="val-form__row val-form__row--1">
            <span class="val-form__label">Brand</span>
            <span class="val-form__value">Salomon</span>
          </div>
          <div class="val-form__row val-form__row--2">
            <span class="val-form__label">Model</span>
            <span class="val-form__value">QST 92</span>
          </div>
          <div class="val-form__row val-form__row--3">
            <span class="val-form__label">Year</span>
            <span class="val-form__value">2021</span>
          </div>
          <div class="val-form__row val-form__row--4">
            <span class="val-form__label">Condition</span>
            <span class="val-form__value">Good</span>
          </div>
          <div class="val-form__row val-form__row--5">
            <span class="val-form__label">Size</span>
            <span class="val-form__value">182cm</span>
          </div>
        </div>
        <p class="val-cta-mock">Estimate value &#x2192;</p>
      </div>

      <div class="val-s val-s--scan">
        <p class="val-s__eyebrow">Analyzing</p>
        <p class="val-s__model val-s__model--dim">QST&nbsp;92</p>
        <div class="val-s__rule"><span class="val-s__rule-fill"></span></div>
        <div class="val-s__progress">
          <div class="val-s__progress-fill"></div>
        </div>
        <div class="val-s__scan-labels">
          <p class="val-s__scan-label val-s__scan-label--1">Searching 14,000+ listings&hellip;</p>
          <p class="val-s__scan-label val-s__scan-label--2">Found 140 comparable sales</p>
          <p class="val-s__scan-label val-s__scan-label--3">Calculating your range&hellip;</p>
        </div>
      </div>

      <div class="val-s val-s--value">
        <p class="val-s__eyebrow">Salomon QST 92 &middot; est. resale</p>
        <p class="val-s__price">$420</p>
        <div class="val-s__rule"><span class="val-s__rule-fill"></span></div>
        <div class="val-s__range">
          <span class="val-s__range-lo">$280</span>
          <div class="val-s__range-track">
            <span class="val-s__range-fill"></span>
            <span class="val-s__range-dot"></span>
          </div>
          <span class="val-s__range-hi">$560</span>
        </div>
        <p class="val-s__comps">140 comparable sales &middot; updated weekly</p>
      </div>

    </div>
  </div>
</header>

<main class="main">

  <section class="preview" aria-label="Sample gear estimate">
    <div class="preview__inner">
      <div class="preview__card" data-reveal>
        <div class="preview__left">
          <p class="preview__tag">Sample estimate</p>
          <h2 class="preview__gear-name">Salomon QST 92</h2>
          <p class="preview__gear-meta">2021 &middot; 182cm &middot; Good condition</p>
        </div>
        <div class="preview__right">
          <p class="preview__result-label">Estimated resale value</p>
          <p class="preview__range">$280<span class="preview__sep"> &mdash; </span>$420</p>
          <p class="preview__basis">Based on 140 transactions &middot; updated weekly</p>
        </div>
      </div>
      <p class="preview__prompt" data-reveal data-delay="120">That's what your estimate looks like. Join the list for day-one access.</p>
    </div>
  </section>

  <section class="form-section" id="join" aria-label="Join the waitlist">
    <div class="form-section__inner">
      <div class="form-card">
        <h2 class="form-card__title">Join the waitlist</h2>
        <p class="form-card__desc">One email when GearWorth opens. No newsletter, no promotions.</p>
        <div id="waitlist-app"></div>
      </div>
    </div>
  </section>

  <section class="pillars" aria-label="What we're building">
    <div class="pillars__inner">
      <div class="pillar" data-reveal>
        <h3 class="pillar__head">Instant estimates</h3>
        <p class="pillar__body">Enter brand, model, year, and condition. A dollar range lands in seconds.</p>
      </div>
      <div class="pillar" data-reveal data-delay="80">
        <h3 class="pillar__head">Real market data</h3>
        <p class="pillar__body">Prices built from thousands of real transactions, refreshed weekly.</p>
      </div>
      <div class="pillar" data-reveal data-delay="160">
        <h3 class="pillar__head">Buy &amp; sell</h3>
        <p class="pillar__body">Post gear directly to skiers who know what it is and what it's worth.</p>
      </div>
    </div>
  </section>

</main>

<footer class="footer">
  <span class="footer__logo">GearWorth</span>
  <span class="footer__copy">&copy; 2026</span>
</footer>

<script src="/js/components/WaitlistForm.js"></script>
<script>
  Vue.createApp(WaitlistForm).mount('#waitlist-app');
</script>
