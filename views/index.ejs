  // Vue and WaitlistForm load deferred; DOMContentLoaded fires after both run.
  document.addEventListener('DOMContentLoaded', () => {
    Vue.createApp(WaitlistForm).mount('#waitlist-app');
    Vue.createApp(WaitlistForm, { audience: 'shop' }).mount('#shop-app');
  });
