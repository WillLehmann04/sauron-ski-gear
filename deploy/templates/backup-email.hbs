{{!--
  PowVal backup report email. One template, both states.
  Data: success(bool) host timestamp stamp file size retained dest output
  Email-client-safe: tables for layout, inline styles, system fonts.
--}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <title>{{#if success}}PowVal backup OK{{else}}PowVal backup FAILED{{/if}}: {{stamp}}</title>
</head>
<body style="margin:0;padding:0;background:#eef2f6;-webkit-text-size-adjust:100%;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
  <!-- preheader: hidden summary shown in inbox preview -->
  <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
    {{#if success}}Backup OK on {{host}} — {{file}} ({{size}}).{{else}}Backup FAILED on {{host}} — no new backup written.{{/if}}
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#eef2f6;padding:24px 12px;">
    <tr><td align="center">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e2e8f0;">

        <!-- header -->
        <tr><td style="background:#091828;padding:18px 28px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
            <td style="font-weight:bold;font-size:20px;letter-spacing:0.04em;color:#ffffff;">POW<span style="color:#e87b1e;">VAL</span></td>
            <td align="right" style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#a8d2f5;">Backup report</td>
          </tr></table>
        </td></tr>

        <!-- status banner -->
        {{#if success}}
        <tr><td style="background:#ecfdf3;border-bottom:1px solid #abefc6;padding:16px 28px;">
          <span style="font-size:13px;font-weight:bold;letter-spacing:0.05em;text-transform:uppercase;color:#067647;">&#10003;&nbsp;&nbsp;Backup successful</span>
        </td></tr>
        {{else}}
        <tr><td style="background:#fef3f2;border-bottom:1px solid #fecdca;padding:16px 28px;">
          <span style="font-size:13px;font-weight:bold;letter-spacing:0.05em;text-transform:uppercase;color:#b42318;">&#10007;&nbsp;&nbsp;Backup failed</span>
        </td></tr>
        {{/if}}

        <!-- body -->
        <tr><td style="padding:28px;">
          <p style="margin:0 0 20px;font-size:15px;line-height:1.55;color:#1c2d3a;">
            {{#if success}}
            The nightly database backup completed successfully on <strong>{{host}}</strong>.
            {{else}}
            The database backup <strong>failed</strong> on <strong>{{host}}</strong>. The live database is unaffected, but <strong>no new backup was written</strong> &mdash; worth a look soon.
            {{/if}}
          </p>

          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-size:14px;color:#1c2d3a;border-collapse:collapse;">
            <tr>
              <td style="padding:9px 0;color:#5a7088;width:110px;vertical-align:top;">When</td>
              <td style="padding:9px 0;vertical-align:top;">{{timestamp}}</td>
            </tr>
            {{#if success}}
            <tr>
              <td style="padding:9px 0;color:#5a7088;border-top:1px solid #eef2f6;vertical-align:top;">File</td>
              <td style="padding:9px 0;border-top:1px solid #eef2f6;font-family:'SFMono-Regular',Consolas,monospace;">{{file}}</td>
            </tr>
            <tr>
              <td style="padding:9px 0;color:#5a7088;border-top:1px solid #eef2f6;vertical-align:top;">Size</td>
              <td style="padding:9px 0;border-top:1px solid #eef2f6;">{{size}}</td>
            </tr>
            <tr>
              <td style="padding:9px 0;color:#5a7088;border-top:1px solid #eef2f6;vertical-align:top;">Retained</td>
              <td style="padding:9px 0;border-top:1px solid #eef2f6;">{{retained}} backups</td>
            </tr>
            <tr>
              <td style="padding:9px 0;color:#5a7088;border-top:1px solid #eef2f6;vertical-align:top;">Location</td>
              <td style="padding:9px 0;border-top:1px solid #eef2f6;font-family:'SFMono-Regular',Consolas,monospace;">{{dest}}</td>
            </tr>
            {{/if}}
          </table>

          {{#unless success}}
          <p style="margin:24px 0 8px;font-size:12px;font-weight:bold;letter-spacing:0.04em;text-transform:uppercase;color:#b42318;">Error output</p>
          <pre style="margin:0;padding:14px 16px;background:#0b1220;color:#e6edf3;border-radius:8px;font-size:12px;line-height:1.5;white-space:pre-wrap;word-break:break-word;font-family:'SFMono-Regular',Consolas,monospace;">{{output}}</pre>
          <p style="margin:18px 0 0;font-size:13px;line-height:1.55;color:#5a7088;">Investigate on the server with <span style="font-family:'SFMono-Regular',Consolas,monospace;">journalctl</span>, and check <span style="font-family:'SFMono-Regular',Consolas,monospace;">{{dest}}</span>.</p>
          {{/unless}}
        </td></tr>

        <!-- footer -->
        <tr><td style="background:#f8fafc;border-top:1px solid #eef2f6;padding:18px 28px;">
          <p style="margin:0;font-size:12px;line-height:1.5;color:#8a9bb0;">Automated report from your PowVal server. Backups run nightly and keep the most recent 14.</p>
        </td></tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
